---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadCV } from '../utils/cv';

const cv = loadCV();
---

<BaseLayout title="Contact — Adrián Hernández Padrón" description="Get in touch.">
  <main class="flex-1 bg-bg">
    <section class="max-w-content mx-auto px-6 pt-16 pb-8">
      <h1 class="font-heading text-gradient mb-4">Contact</h1>
      <p class="text-lg text-ink-muted max-w-[600px]">
        Interested in collaborating, discussing data products, or building production AI systems? Reach out and I'll get back to you.
      </p>
    </section>

    <hr class="border-border mx-auto max-w-content" />

    <section class="max-w-content mx-auto px-6 py-12">
      <div class="max-w-[760px] space-y-6">
        <div class="rounded-[24px] border border-border bg-bg-surface p-6">
          <p class="mb-3 text-xs font-mono uppercase tracking-[0.18em] text-ink-faint">Quick snapshot</p>
          <div class="grid gap-4 sm:grid-cols-3">
            <div>
              <p class="mb-1 text-sm text-ink-muted">Location</p>
              <p class="m-0 text-sm font-medium text-ink">{cv.location}</p>
            </div>
            <div>
              <p class="mb-1 text-sm text-ink-muted">Current role</p>
              <p class="m-0 text-sm font-medium text-ink">Senior Data Scientist</p>
            </div>
            <div>
              <p class="mb-1 text-sm text-ink-muted">Focus</p>
              <p class="m-0 text-sm font-medium text-ink">ML systems, MLOps, and AI products</p>
            </div>
          </div>
        </div>

        <div class="rounded-[28px] border border-border bg-bg-surface p-6 sm:p-8 shadow-[0_20px_60px_rgba(47,52,55,0.06)]">
          <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <p class="mb-2 text-xs font-mono uppercase tracking-[0.18em] text-ink-faint">Available for selected work</p>
              <h2 class="font-heading text-2xl text-ink mb-2">Let's start with a conversation</h2>
              <p class="m-0 max-w-[34rem] text-sm leading-relaxed text-ink-muted">
                Best fit for senior data science, ML systems, MLOps, and AI product work. If you share the context, I can quickly tell you whether I'm the right person to help.
              </p>
            </div>
            <a
              href="/adrian-cv.pdf"
              download
              class="inline-flex items-center justify-center gap-2 rounded-full border border-border bg-bg-elevated px-4 py-2.5 text-sm font-medium text-ink no-underline hover:border-accent hover:text-accent"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v12m0 0l4-4m-4 4l-4-4m-5 8h18" />
              </svg>
              Download CV
            </a>
          </div>

          <div class="grid gap-3">
            <a href={`mailto:${cv.email}`} class="flex items-center justify-between gap-4 rounded-2xl border border-border bg-bg-elevated px-4 py-4 text-ink no-underline hover:border-accent hover:bg-accent/10 transition-colors group">
              <div>
                <p class="m-0 text-xs font-mono uppercase tracking-[0.16em] text-ink-faint">Email</p>
                <p class="m-0 mt-1 text-sm font-medium group-hover:text-accent">{cv.email}</p>
              </div>
              <span class="text-sm text-ink-muted group-hover:text-accent">Primary</span>
            </a>
            <a href={`https://github.com/${cv.github}`} target="_blank" rel="noopener noreferrer" class="flex items-center justify-between gap-4 rounded-2xl border border-border bg-bg-elevated px-4 py-4 text-ink no-underline hover:border-accent hover:bg-accent/10 transition-colors group">
              <div>
                <p class="m-0 text-xs font-mono uppercase tracking-[0.16em] text-ink-faint">GitHub</p>
                <p class="m-0 mt-1 text-sm font-medium group-hover:text-accent">{cv.github}</p>
              </div>
              <span class="text-sm text-ink-muted group-hover:text-accent">Projects</span>
            </a>
            <a href={`https://linkedin.com/in/${cv.linkedin}`} target="_blank" rel="noopener noreferrer" class="flex items-center justify-between gap-4 rounded-2xl border border-border bg-bg-elevated px-4 py-4 text-ink no-underline hover:border-accent hover:bg-accent/10 transition-colors group">
              <div>
                <p class="m-0 text-xs font-mono uppercase tracking-[0.16em] text-ink-faint">LinkedIn</p>
                <p class="m-0 mt-1 text-sm font-medium group-hover:text-accent">{cv.linkedin}</p>
              </div>
              <span class="text-sm text-ink-muted group-hover:text-accent">Profile</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
