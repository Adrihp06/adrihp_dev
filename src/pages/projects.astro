---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const featured = projects.filter((p) => p.data.featured);
const others = projects.filter((p) => !p.data.featured);
---

<BaseLayout title="Projects — Adrián Hernández Padrón" description="A selection of AI, MLOps, and data science projects.">
  <main class="flex-1 bg-bg">
    <section class="max-w-content mx-auto px-6 pt-20 pb-12">
      <h1 class="mb-4 font-heading text-gradient">Projects</h1>
      <p class="text-lg text-ink-muted max-w-[600px] leading-relaxed">
        A selection of work spanning AI engineering, MLOps pipelines, and data science research.
      </p>
    </section>

    <hr class="border-border mx-auto max-w-content" />

    {featured.length > 0 && (
      <section class="max-w-content mx-auto px-6 py-14">
        <h2 class="mb-10 text-sm font-heading font-semibold text-accent uppercase tracking-[0.2em]">Featured</h2>
        <div class="space-y-8">
          {featured.map((project) => (
            <article class="group relative bg-bg-surface border border-border rounded-xl p-6 pl-8 border-l-2 border-l-accent/60 hover:border-accent/30 hover:shadow-[0_0_24px_-6px_rgba(99,102,241,0.15)] transition-all duration-300">
              <h3 class="mb-2 font-heading text-xl font-semibold text-ink">{project.data.title}</h3>
              <p class="text-ink-muted mb-5 leading-relaxed">{project.data.description}</p>
              <div class="flex flex-wrap gap-2 mb-5">
                {project.data.tags.map((tag) => (
                  <span class="text-xs font-mono px-3 py-1 bg-accent/10 text-accent-light rounded-full">{tag}</span>
                ))}
              </div>
              <div class="flex gap-5">
                {project.data.repo && (
                  <a href={project.data.repo} target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-accent no-underline hover:text-accent-light transition-colors">
                    Repository &rarr;
                  </a>
                )}
                {project.data.link && (
                  <a href={project.data.link} target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-accent no-underline hover:text-accent-light transition-colors">
                    Live &rarr;
                  </a>
                )}
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    {others.length > 0 && (
      <>
        <hr class="border-border mx-auto max-w-content" />
        <section class="max-w-content mx-auto px-6 py-14">
          <h2 class="mb-10 text-sm font-heading font-semibold text-ink-muted uppercase tracking-[0.2em]">More Work</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {others.map((project) => (
              <article class="group bg-bg-surface border border-border rounded-xl p-5 hover:border-accent/30 hover:shadow-[0_0_20px_-6px_rgba(99,102,241,0.12)] transition-all duration-300">
                <h3 class="text-base font-heading font-semibold text-ink mb-2">{project.data.title}</h3>
                <p class="text-sm text-ink-muted mb-4 leading-relaxed">{project.data.description}</p>
                <div class="flex flex-wrap gap-2">
                  {project.data.tags.map((tag) => (
                    <span class="text-xs font-mono px-3 py-1 bg-accent/10 text-accent-light rounded-full">{tag}</span>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </section>
      </>
    )}

    {projects.length === 0 && (
      <section class="max-w-content mx-auto px-6 py-14">
        <p class="text-ink-muted font-sans">Projects coming soon.</p>
      </section>
    )}
  </main>
</BaseLayout>
