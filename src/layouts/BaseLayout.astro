---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Adrián Hernández Padrón',
  description = 'Senior Data Scientist & AI Engineer — Personal portfolio and blog'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-bg text-ink font-sans min-h-screen flex flex-col leading-relaxed">
    <Navigation />
    <slot />
    <Footer />
  </body>
</html>

<style is:global>
  h1, h2, h3, h4, h5, h6 {
    font-family: 'Space Grotesk', 'Plus Jakarta Sans', system-ui, sans-serif;
    font-weight: 600;
    line-height: 1.15;
  }

  h1 {
    font-size: clamp(2.25rem, 5vw, 3.25rem);
    letter-spacing: -0.03em;
  }

  h2 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    letter-spacing: -0.02em;
  }

  h3 {
    font-size: clamp(1.25rem, 3vw, 1.5rem);
    letter-spacing: -0.01em;
  }

  .prose h1, .prose h2, .prose h3, .prose h4 {
    font-family: 'Space Grotesk', 'Plus Jakarta Sans', system-ui, sans-serif;
  }

  .prose {
    --tw-prose-body: #2f3437;
    --tw-prose-headings: #2f3437;
    --tw-prose-links: #8fa7a1;
    --tw-prose-bold: #2f3437;
    --tw-prose-code: #7f94ae;
    --tw-prose-pre-bg: #ece8e1;
    --tw-prose-pre-code: #2f3437;
    --tw-prose-quotes: #6f7681;
    --tw-prose-hr: #d8d3cb;
    --tw-prose-counters: #6f7681;
    --tw-prose-bullets: #8fa7a1;
  }

  html {
    scroll-behavior: smooth;
  }

  ::selection {
    background-color: #c5b7cf;
    color: #2f3437;
  }

  a, button {
    transition: all 0.2s ease-in-out;
  }

  /* Gradient text utility */
  .text-gradient {
    background: linear-gradient(135deg, #7f94ae, #b8a9c4, #8fa7a1);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .text-gradient-vivid {
    background: linear-gradient(135deg, #ff7aa2, #8b8cfb, #34c6d3, #8ccf7e);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Glow effect utility */
  .glow {
    box-shadow: 0 10px 30px rgba(143, 167, 161, 0.12), 0 4px 18px rgba(184, 169, 196, 0.08);
  }

  .glow-sm {
    box-shadow: 0 8px 16px rgba(143, 167, 161, 0.1);
  }

  /* Custom scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
  }

  ::-webkit-scrollbar-track {
    background: #f3f1ec;
  }

  ::-webkit-scrollbar-thumb {
    background: #cfc8be;
    border-radius: 4px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: #8fa7a1;
  }

  /* Subtle grid pattern for backgrounds */
  .bg-grid {
    background-image:
      linear-gradient(rgba(143, 167, 161, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(184, 169, 196, 0.08) 1px, transparent 1px);
    background-size: 60px 60px;
  }
</style>
